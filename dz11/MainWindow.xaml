<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Личный кабинет" Height="500" Width="900">

    <Grid>

        <Grid Name="LoginGrid">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="250">

                <TextBlock Text="Логин" />
                <TextBox Name="tbLogin" Margin="0,5"/>

                <TextBlock Text="Пароль" Margin="0,10,0,0"/>
                <PasswordBox Name="tbPassword" Margin="0,5"/>

                <Button Content="Войти"
                        Height="35"
                        Margin="0,15,0,0"
                        Click="Login_Click"/>
            </StackPanel>
        </Grid>

        <Grid Name="CabinetGrid" Visibility="Collapsed">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Background="#2C3E50">

                <Button Content="Профиль" Height="50" Click="Profile_Click"/>
                <Button Content="Настройки" Height="50" Click="Settings_Click"/>
                <Button Content="Заказы" Height="50" Click="Orders_Click"/>

            </StackPanel>

            <Grid Grid.Column="1" Name="ContentGrid" Margin="20">

                <StackPanel Name="ProfilePanel">

                    <TextBlock Text="Профиль" FontSize="24"/>

                    <TextBlock Text="ФИО:"/>
                    <TextBlock Name="tbFio" Text="Иван Иванов"/>

                    <TextBlock Text="Телефон:" Margin="0,10,0,0"/>
                    <TextBlock Name="tbPhone" Text="+7 999 000 00 00"/>

                    <TextBlock Text="Email:" Margin="0,10,0,0"/>
                    <TextBlock Name="tbEmail" Text="test@mail.com"/>

                </StackPanel>

                <StackPanel Name="SettingsPanel" Visibility="Collapsed">

                    <TextBlock Text="Настройки" FontSize="24"/>

                    <TextBlock Text="Изменить ФИО"/>
                    <TextBox Name="editFio"/>

                    <TextBlock Text="Изменить Email" Margin="0,10,0,0"/>
                    <TextBox Name="editEmail"/>

                    <Button Content="Сохранить"
                            Margin="0,15,0,0"
                            Click="SaveSettings_Click"/>
                </StackPanel>

                <StackPanel Name="OrdersPanel" Visibility="Collapsed">

                    <TextBlock Text="Выбор заказа" FontSize="24"/>

                    <ListBox Name="ordersList">
                        <ListBoxItem Content="Заказ №1"/>
                        <ListBoxItem Content="Заказ №2"/>
                        <ListBoxItem Content="Заказ №3"/>
                    </ListBox>

                </StackPanel>

            </Grid>

        </Grid>

    </Grid>
</Window>